{
  // ═══════════════════════════════════════════════════════════════════════════
  // Azure AD App Registration
  // Used for OneDrive and SharePoint sources.
  // TenantId + ClientId are also reused by AzureBlob.ClientCredentials mode.
  // ═══════════════════════════════════════════════════════════════════════════
  "AzureAd": {
    "TenantId": "1b91cb33-baee-4707-8b9e-c394f3f164f2",
    "ClientId": "f9a7464a-e21d-4a0e-8f08-747d45fe41da",

    // ── AUTH MODE TOGGLE ──────────────────────────────────────────────────
    // "ClientCredentials" — app-only, no browser. For Autosys / scheduled jobs.
    //     App registration: API permissions → Files.Read.All, Sites.Read.All
    //                       (Application type, admin-consented)
    // "Interactive"       — browser login on first run; MSAL token cached to disk.
    //     App registration: API permissions → Files.Read, Files.Read.All, Sites.Read.All
    //                       (Delegated type)
    //                       Platform: Mobile and desktop, redirect http://localhost
    //                       Allow public client flows: Yes
    // Override at runtime: --auth-mode Interactive
    "AuthMode": "ClientCredentials",

    // Required when AuthMode = "ClientCredentials"
    "ClientSecret": "",

    "InteractiveLogin": {
      // Directory for the MSAL token cache file (DPAPI-encrypted on Windows).
      // Browser opens only on first run; subsequent runs use the cached token.
      // Leave blank to place the cache next to the exe.
      "TokenCacheDir": "",
      // Must match the redirect URI registered in Azure AD.
      "RedirectUri": "http://localhost"
    }
  },

  // ═══════════════════════════════════════════════════════════════════════════
  // SOURCE MODE — change this ONE value to switch between all three sources
  //   "OneDrive"   → user's OneDrive via Graph REST API
  //   "SharePoint" → SharePoint document library via Graph REST API
  //   "AzureBlob"  → Azure Blob Storage container (own auth, no Graph)
  // ═══════════════════════════════════════════════════════════════════════════
  "SourceMode": "OneDrive",

  // ═══════════════════════════════════════════════════════════════════════════
  // OneDrive settings  (used when SourceMode = "OneDrive")
  // ═══════════════════════════════════════════════════════════════════════════
  "OneDrive": {
    // UPN or object ID of the drive owner.
    // Required when AuthMode = "ClientCredentials".
    // Optional when AuthMode = "Interactive" — leave blank to use /me/drive.
    "UserId": "KamleshSharma@NextStar.onmicrosoft.com",
    // Folder inside drive root, excluding the date folder. e.g. "Reports"
    "BaseFolderPath": "Reports"
  },

  // ═══════════════════════════════════════════════════════════════════════════
  // SharePoint settings  (used when SourceMode = "SharePoint")
  // ═══════════════════════════════════════════════════════════════════════════
  "SharePoint": {
    "Hostname": "nextstar.sharepoint.com",
    "SitePath": "sites/NextStarHomeSite",
    "LibraryName": "Documents",
    "BaseFolderPath": "Reports"
  },

  // ═══════════════════════════════════════════════════════════════════════════
  // Azure Blob settings  (used when SourceMode = "AzureBlob")
  //
  // AzureBlob.AuthMode options (independent of AzureAd.AuthMode):
  //   "ConnectionString"  — full storage connection string. Simplest.
  //   "ClientCredentials" — AAD app identity. Reuses AzureAd credentials.
  //                         App needs Storage Blob Data Reader role.
  //   "ManagedIdentity"   — VM/App Service identity. No secrets.
  //                         Managed identity needs Storage Blob Data Reader role.
  // ═══════════════════════════════════════════════════════════════════════════
  "AzureBlob": {
    "AuthMode": "ConnectionString",
    "ConnectionString": "DefaultEndpointsProtocol=https;AccountName=YOUR_ACCOUNT;AccountKey=YOUR_KEY;EndpointSuffix=core.windows.net",
    "AccountUri": "https://YOUR_ACCOUNT.blob.core.windows.net",
    "ContainerName": "reports",
    // Virtual folder prefix inside the container, excluding the date folder.
    // e.g. "finance/reports" → blobs at "finance/reports/20260522/file.xlsx"
    // Leave blank if files sit at "20260522/file.xlsx" (container root).
    "BaseFolderPrefix": "finance/reports"
  },

  // ═══════════════════════════════════════════════════════════════════════════
  // Destination — network mapped drive or UNC path
  // Date folder is appended: "Z:\\Reports" → "Z:\\Reports\\20260522"
  // ═══════════════════════════════════════════════════════════════════════════
  "Destination": {
    "RootPath": "N:\\Reports"
  },

  // ═══════════════════════════════════════════════════════════════════════════
  // Per-file copy options
  // ═══════════════════════════════════════════════════════════════════════════
  "CopyOptions": {
    "Overwrite": false,
    "FileFilter": "*.xls,*.xlsx",
    // Per-file retry attempts on transient errors (distinct from RetryPolicy below)
    "MaxRetries": 3,
    "RetryDelaySeconds": 1
  },

  // ═══════════════════════════════════════════════════════════════════════════
  // Outer retry policy — Autosys-style: retry the full run until files appear
  //
  // Designed for: upstream ETL writes files at an unpredictable time.
  // The job runs every DelayMinutes and retries up to MaxAttempts times,
  // stopping early if MaxDurationHours has elapsed.
  //
  // Retries on:    SourceNotFound (2), TotalFailure (5)
  // Does NOT retry: InvalidArguments (1), DestUnreachable (3),
  //                 PartialFailure (4), AuthFailure (6)
  //
  // Default: 30 attempts × 10 min delay = up to 5 hours
  // ═══════════════════════════════════════════════════════════════════════════
  "RetryPolicy": {
    "MaxAttempts": 30,
    "DelayMinutes": 10,
    "MaxDurationHours": 5.0
  },

  // ═══════════════════════════════════════════════════════════════════════════
  // Logging — leave LogDirectory blank to write logs next to the exe
  // ═══════════════════════════════════════════════════════════════════════════
  "Logging": {
    "LogDirectory": ""
  }
}
